
// MODELO RELACIONAL

// Enums

Enum gender_type {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}

Enum alert_severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

Enum alert_status {
  ACTIVE
  RESOLVED
  DISMISSED
}

Enum recommendation_priority {
  LOW
  MEDIUM
  HIGH
}

Enum recommendation_status {
  ACTIVE
  COMPLETED
  EXPIRED
  DISMISSED
}

Enum record_source_type {
  MANUAL
  RULE
  SYSTEM
}


Table roles {

  id bigint [pk, increment]


  name varchar(30) [not null, unique]

  description varchar(255)

  created_at timestamp [not null, default: `now()`]


  updated_at timestamp [not null, default: `now()`]

  Note: 'Valores iniciales: ADMIN, DOCTOR, PATIENT'
}

Table users {
  id bigint [pk, increment]
  role_id bigint [not null]

  email varchar(150) [not null, unique]


  password_hash varchar(255) [not null]

  is_active boolean [not null, default: true]


  last_login timestamp

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table refresh_tokens {
  id bigint [pk, increment]

  user_id bigint [not null]

  token_hash varchar(255) [not null]
  expires_at timestamp [not null]
  revoked_at timestamp

  created_at timestamp [not null, default: `now()`]
}

Table password_reset_tokens {
  id bigint [pk, increment]
  user_id bigint [not null]

  token_hash varchar(255) [not null]
  expires_at timestamp [not null]
  used_at timestamp

  created_at timestamp [not null, default: `now()`]
}



// Perf Clínicos


Table doctors {
  id bigint [pk, increment]
  user_id bigint [not null, unique]


  first_name varchar(100) [not null]


  last_name varchar(100) [not null]

  specialty varchar(100)
  
  phone varchar(30)

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Cada médico está asociado a una cuenta de usuario.'
}

Table patients {
  id bigint [pk, increment]



  doctor_id bigint [not null]
  user_id bigint [unique]

  first_name varchar(100) [not null]




  last_name varchar(100) [not null]

  gender gender_type [not null, default: 'NOT_SPECIFIED']

  birth_date date



  height_cm decimal(5,2)

  is_active boolean [not null, default: true]

  created_at timestamp [not null, default: `now()`]

  updated_at timestamp [not null, default: `now()`]

  Note: 'Cada paciente posee un médico responsable. user_id es para poder registrar pacientes antes de que tengan acceso al sistema pero se puede cambiar si queremos.'
}



// Dispositivos & otros datos


Table patient_devices {
  id bigint [pk, increment]
  patient_id bigint [not null]

  device_name varchar(100) [not null]

  device_type varchar(100) [not null]


  manufacturer varchar(100)

  external_device_id varchar(150)



  source varchar(100) [not null]

  is_active boolean [not null, default: true]

  last_sync_at timestamp

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Indexes {


    (patient_id, external_device_id) [unique]
  }


  Note: 'Dispositivos asociados al paciente.'
}

Table devices_data {
  id bigint [pk, increment]

  patient_id bigint [not null]


  patient_device_id bigint

  data_type varchar(100) [not null]



  data_value decimal(12,2)
  unit varchar(30)

  recorded_at timestamp [not null]

  source varchar(100)

  raw_payload jsonb

  ingested_at timestamp [not null, default: `now()`]

  Indexes {
    (patient_id, recorded_at)
    (patient_device_id, recorded_at)
  }

  Note: 'Datos recibidos desde pulsera médica, Health Connect, wearables o otros dispositivos si queremos hacer otros.'
}



// Métricas e Historial


Table measurements {
  id bigint [pk, increment]



  patient_id bigint [not null]

  measurement_date timestamp [not null]

  weight_kg decimal(6,2)



  bmi decimal(5,2)

  body_fat_percentage decimal(5,2)

  muscle_mass_kg decimal(6,2)





  visceral_fat decimal(5,2)


  body_water_percentage decimal(5,2)

  created_at timestamp [not null, default: `now()`]


  Indexes {




    (patient_id, measurement_date)

  }

  Note: 'Peso, IMC, grasa corporal, masa muscular, grasa visceral y agua corporal.'
}

Table vitals {
  id bigint [pk, increment]


  patient_id bigint [not null]

  measurement_date timestamp [not null]


  heart_rate int



  hrv int
  spo2 decimal(5,2)

  created_at timestamp [not null, default: `now()`]

  Indexes {



    (patient_id, measurement_date)
  }

  Note: 'Frecuencia cardíaca, variabilidad cardíaca y nivel de oxígeno en sangre.'
}

Table sleep {
  id bigint [pk, increment]


  patient_id bigint [not null]



  sleep_date date [not null]

  sleep_duration_minutes int


  deep_sleep_minutes int


  light_sleep_minutes int

  rem_sleep_minutes int

  sleep_score int

  created_at timestamp [not null, default: `now()`]

  Indexes {



    (patient_id, sleep_date)


  }

}

Table activity {
  id bigint [pk, increment]


  patient_id bigint [not null]

  activity_date date [not null]

  steps int
  distance_km decimal(8,2)


  calories_burned decimal(10,2)

  exercise_minutes int



  created_at timestamp [not null, default: `now()`]


  Indexes {


    (patient_id, activity_date)

  }
}

Table nutrition {
  id bigint [pk, increment]

  patient_id bigint [not null]


  nutrition_date date [not null]



  calories decimal(10,2)




  protein_g decimal(8,2)




  carbohydrates_g decimal(8,2)


  fat_g decimal(8,2)

  water_ml int

  created_at timestamp [not null, default: `now()`]

  Indexes {
    (patient_id, nutrition_date)
  }
}



// Notificaciones/Alertas & Recomendaciones

Table alerts {
  id bigint [pk, increment]

  patient_id bigint [not null]


  created_by_user_id bigint

  severity alert_severity [not null]



  category varchar(100) [not null]

  message text [not null]

  status alert_status [not null, default: 'ACTIVE']


  source_type record_source_type [not null, default: 'SYSTEM']



  created_at timestamp [not null, default: `now()`]


  resolved_at timestamp

  Indexes {
    (patient_id, status)

    (patient_id, severity)
    (patient_id, created_at)
  }

  Note: 'Puede ser creada manualmente por un médico o por una regla del sistema si queremos hacerlo así'
}

Table recommendations {



  id bigint [pk, increment]

  patient_id bigint [not null]

  created_by_user_id bigint

  priority recommendation_priority [not null]


  title varchar(150) [not null]


  description text [not null]


  status recommendation_status [not null, default: 'ACTIVE']

  source_type record_source_type [not null, default: 'SYSTEM']



  created_at timestamp [not null, default: `now()`]

  completed_at timestamp

  Indexes {


    (patient_id, status)

    (patient_id, priority)
    (patient_id, created_at)

  }

  Note: 'Las recomendaciones del MVP pueden ser creadas por médico, administrador o reglas simples.'
}



// Seguimiento


Table medical_notes {
  id bigint [pk, increment]

  patient_id bigint [not null]

  doctor_id bigint [not null]

  note text [not null]

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Indexes {
    (patient_id, created_at)
  }

  Note: 'Observaciones médicas registradas por el médico responsable.'


}



// Auditoría


Table audit_logs {


  id bigint [pk, increment]


  user_id bigint

  action varchar(100) [not null]



  entity varchar(100) [not null]


  entity_id bigint

  metadata_json jsonb

  ip_address varchar(45)

  occurred_at timestamp [not null, default: `now()`]

  Indexes {
    (user_id, occurred_at)
    (entity, entity_id)
  }

  Note: 'Acciones críticas como inicio de sesión, creación o modificación de pacientes, notas y exportaciones.'
}



// Relaciones para el gráfico como tal


Ref: users.role_id > roles.id

Ref: doctors.user_id > users.id

Ref: patients.doctor_id > doctors.id
Ref: patients.user_id > users.id

Ref: refresh_tokens.user_id > users.id
Ref: password_reset_tokens.user_id > users.id

Ref: patient_devices.patient_id > patients.id

Ref: devices_data.patient_id > patients.id
Ref: devices_data.patient_device_id > patient_devices.id

Ref: measurements.patient_id > patients.id
Ref: vitals.patient_id > patients.id
Ref: sleep.patient_id > patients.id
Ref: activity.patient_id > patients.id
Ref: nutrition.patient_id > patients.id

Ref: alerts.patient_id > patients.id
Ref: alerts.created_by_user_id > users.id

Ref: recommendations.patient_id > patients.id
Ref: recommendations.created_by_user_id > users.id

Ref: medical_notes.patient_id > patients.id
Ref: medical_notes.doctor_id > doctors.id

Ref: audit_logs.user_id > users.id